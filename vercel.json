{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "pwa-app-store.com" }],
      "destination": "https://www.pwa-app-store.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}

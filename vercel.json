{
  "redirects": [
    {
      "source": "/((?!api/).*)",
      "has": [{ "type": "host", "value": "agentslock.com" }],
      "destination": "https://www.agentslock.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    {
      "source": "/((?!.*\\.(?:png|jpg|jpeg|gif|svg|webp|ico|txt|xml|json|map|css|js|woff|woff2)$).*)",
      "destination": "/index.html"
    }
  ]
}

# SafeLaunch — Environment Variables
# Copy this to .env.local and fill in your values
# Add these same keys to Vercel → Project Settings → Environment Variables

# ── Firebase (client-side — MUST start with VITE_) ─────────────────────────
# Get these from: Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=pwa-app-store-138e7.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=pwa-app-store-138e7
VITE_FIREBASE_STORAGE_BUCKET=pwa-app-store-138e7.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=861915608754
VITE_FIREBASE_APP_ID=

# ── Firebase Admin (backend-only — Vercel serverless, NO VITE_ prefix) ─────
# Used by /api/apps, /api/health, /api/diagnostics
# Set ONE of these in Vercel Environment Variables:
#   FIREBASE_SERVICE_ACCOUNT_BASE64  (recommended — base64 of service account JSON)
#   FIREBASE_SERVICE_ACCOUNT_JSON    (raw JSON string of service account)

# ── PayPal (client-side — browser-exposed) ──────────────────────────────────
# Get from: PayPal Developer Dashboard → My Apps & Credentials
VITE_PAYPAL_CLIENT_ID=
VITE_PAYPAL_ENV=sandbox

# ── PayPal (backend-only — Vercel serverless, NO VITE_ prefix) ─────────────
# These are NEVER exposed to the browser. Set in Vercel Environment Variables only.
# PAYPAL_CLIENT_ID=          (same as VITE_PAYPAL_CLIENT_ID)
# PAYPAL_CLIENT_SECRET=      (from PayPal Developer Dashboard)
# PAYPAL_ENV=sandbox         (set to 'live' for production — must match VITE_PAYPAL_ENV)
# PAYPAL_WEBHOOK_ID=         (required for webhook signature verification)

# ── Management Login (backend-only) ────────────────────────────────────────
# Used by /api/send-code and /api/verify-code for management access
# MGMT_SECRET=               (random string for HMAC-signing verification codes — REQUIRED in production)

# ── SMTP (backend-only) ────────────────────────────────────────────────────
# Used by /api/send-code to email verification codes
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=                 (app-specific password for Gmail)
# SMTP_FROM=                 (optional — defaults to SMTP_USER)

# ── Cron Jobs (backend-only) ───────────────────────────────────────────────
# Used by /api/jobs/recalculateRankings to authenticate cron triggers
# CRON_SECRET=               (random string — REQUIRED to prevent unauthorized triggers)

# ── Security Scanning (backend-only) ──────────────────────────────────────
# Used by /api/security/staticScan for Google Safe Browsing checks
# GOOGLE_SAFE_BROWSING_KEY=  (from Google Cloud Console → APIs → Safe Browsing API)

# ── SEO / Verification ─────────────────────────────────────────────────────
# Google: Search Console → Settings → Ownership verification → HTML tag
# GOOGLE_SITE_VERIFICATION=
# Bing: Webmaster Tools → Settings → Verify ownership → HTML meta tag
# BING_SITE_VERIFICATION=

# SafeLaunch — Environment Variables
# Copy this to .env.local and fill in your values
# Add these same keys to Vercel → Project Settings → Environment Variables

# ── Firebase (client-side — MUST start with VITE_) ─────────────────────────
# Get these from: Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=pwa-app-store-138e7.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=pwa-app-store-138e7
VITE_FIREBASE_STORAGE_BUCKET=pwa-app-store-138e7.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=861915608754
VITE_FIREBASE_APP_ID=

# ── PayPal (client-side — browser-exposed) ──────────────────────────────────
# Get from: PayPal Developer Dashboard → My Apps & Credentials
VITE_PAYPAL_CLIENT_ID=
VITE_PAYPAL_ENV=sandbox

# ── PayPal (backend-only — Vercel serverless, NO VITE_ prefix) ─────────────
# These are NEVER exposed to the browser. Set in Vercel Environment Variables only.
# PAYPAL_CLIENT_ID=          (same as VITE_PAYPAL_CLIENT_ID)
# PAYPAL_CLIENT_SECRET=      (from PayPal Developer Dashboard)
# PAYPAL_WEBHOOK_ID=         (optional, for webhook verification)

# ── PayPal Subscription Plan IDs (optional, for future subscription flow) ───
# VITE_PAYPAL_PLAN_LITE=
# VITE_PAYPAL_PLAN_PRO=
# VITE_PAYPAL_PLAN_BUSINESS=

# ── SEO / Verification ─────────────────────────────────────────────────────
# Google: Search Console → Settings → Ownership verification → HTML tag
# GOOGLE_SITE_VERIFICATION=
# Bing: Webmaster Tools → Settings → Verify ownership → HTML meta tag
# BING_SITE_VERIFICATION=

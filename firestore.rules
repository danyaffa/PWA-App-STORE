rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isOwner(resourceData) {
      return signedIn() && resourceData.developerUid == request.auth.uid;
    }

    // ── USERS ──────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if signedIn() && request.auth.uid == uid
        && !('role' in request.resource.data);
      // Admin role assignment should be done manually in console or via admin-only tooling
    }

    // ── APPS ───────────────────────────────────────────────────────────────
    match /apps/{appId} {
      // Anyone can read apps
      allow read: if true;

      // Anyone can create/update apps (app uses localStorage auth for demo)
      allow create, update: if true;

      // Delete: admin only
      allow delete: if isAdmin();
    }

    // ── REVIEWS ────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;

      // Create review only for self, rating between 1-5
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;

      // Update/Delete only own review (or admin)
      allow update, delete: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
    }

    // ── SCANS ──────────────────────────────────────────────────────────────
    match /scans/{scanId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.submittedByUid == request.auth.uid);

      allow create: if signedIn()
        && request.resource.data.submittedByUid == request.auth.uid;

      // Only admin can update scan results/reports
      allow update, delete: if isAdmin();
    }

    // ── AGREEMENTS ─────────────────────────────────────────────────────
    match /agreements/{docId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── ANALYTICS ────────────────────────────────────────────────────────
    match /analytics/{appId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    // ── SEARCH QUERIES ───────────────────────────────────────────────────
    match /searchQueries/{docId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if false;
    }

    // ── DEVELOPERS ───────────────────────────────────────────────────────
    match /developers/{uid} {
      allow read: if true;
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if signedIn() && request.auth.uid == uid
        && !('verificationLevel' in request.resource.data);
      allow delete: if isAdmin();
    }

    // ── REPORTS (User Abuse Reports) ─────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // ── REFERRALS ────────────────────────────────────────────────────────
    match /referrals/{refId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.referrerId == request.auth.uid);
      allow create: if true;
      allow update, delete: if false;
    }

    // ── Default deny ───────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
